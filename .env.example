NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
SUPABASE_DB_PASS=<your-db-password>

# Secret que autoriza o Vercel Cron Job a chamar /api/cron/billing-reminders.
# Setar o mesmo valor na env da Vercel — o Cron Jobs da Vercel envia
# automaticamente "Authorization: Bearer $CRON_SECRET" quando essa env existe.
CRON_SECRET=<gerar-uma-string-aleatoria>
